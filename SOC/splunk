<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Splunk SIEM Investigation Portfolio — M. Usamanur Rahman Biplob</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
  :root {
    --bg-deep: #0a0e17;
    --bg-primary: #0d1320;
    --bg-card: #111827;
    --bg-card-hover: #162032;
    --bg-elevated: #1a2332;
    --border: #1e2d3d;
    --border-accent: #0f766e;
    --text-primary: #e8edf5;
    --text-secondary: #8b9bb4;
    --text-muted: #5a6a82;
    --accent: #14b8a6;
    --accent-bright: #2dd4bf;
    --accent-dim: #0d9488;
    --danger: #ef4444;
    --danger-dim: #991b1b;
    --warning: #f59e0b;
    --warning-dim: #92400e;
    --success: #22c55e;
    --success-dim: #14532d;
    --info: #06b6d4;
    --purple: #a78bfa;
    --gradient-accent: linear-gradient(135deg, #14b8a6, #06b6d4);
    --gradient-danger: linear-gradient(135deg, #ef4444, #f97316);
    --gradient-warm: linear-gradient(135deg, #f59e0b, #ef4444);
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.4);
    --shadow-md: 0 4px 12px rgba(0,0,0,0.5);
    --shadow-lg: 0 8px 32px rgba(0,0,0,0.6);
    --shadow-glow: 0 0 30px rgba(20,184,166,0.15);
    --radius: 10px;
    --radius-lg: 16px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
    font-size: 15px;
  }

  body {
    font-family: 'Space Grotesk', sans-serif;
    background: var(--bg-deep);
    color: var(--text-primary);
    line-height: 1.7;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  /* === 背景氛围 === */
  body::before {
    content: '';
    position: fixed;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(20,184,166,0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  body::after {
    content: '';
    position: fixed;
    bottom: -300px;
    left: -200px;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(6,182,212,0.04) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* === 网格背景 === */
  .grid-bg {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(20,184,166,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(20,184,166,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 1;
  }

  /* === 封面 === */
  .cover {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 60px 24px;
    position: relative;
  }

  .cover-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 18px;
    border-radius: 999px;
    background: rgba(20,184,166,0.1);
    border: 1px solid rgba(20,184,166,0.25);
    color: var(--accent-bright);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 32px;
    animation: fadeSlideUp 0.8s ease-out;
  }

  .cover-title {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
    animation: fadeSlideUp 0.8s ease-out 0.15s both;
  }
  .cover-title .highlight {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cover-subtitle {
    font-size: 1.15rem;
    color: var(--text-secondary);
    max-width: 640px;
    margin-bottom: 40px;
    animation: fadeSlideUp 0.8s ease-out 0.3s both;
  }

  .cover-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    animation: fadeSlideUp 0.8s ease-out 0.45s both;
  }

  .meta-chip {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 8px 16px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.82rem;
    color: var(--text-secondary);
  }
  .meta-chip i {
    color: var(--accent);
    font-size: 0.85rem;
  }

  .cover-divider {
    width: 60px;
    height: 3px;
    background: var(--gradient-accent);
    border-radius: 3px;
    margin: 40px auto;
    animation: fadeSlideUp 0.8s ease-out 0.55s both;
  }

  .cover-analyst {
    animation: fadeSlideUp 0.8s ease-out 0.6s both;
  }
  .cover-analyst .name {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  .cover-analyst .role {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 2px;
  }

  .scroll-hint {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    animation: bounce 2s infinite;
  }
  .scroll-hint i { font-size: 1rem; }

  /* === 目录 === */
  .toc-section {
    padding: 80px 0 60px;
  }
  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
  }
  .section-label::before {
    content: '';
    width: 20px;
    height: 2px;
    background: var(--accent);
    border-radius: 2px;
  }

  .section-title {
    font-size: 1.9rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 32px;
  }

  .toc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .toc-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    color: inherit;
  }
  .toc-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
  }
  .toc-num {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    font-weight: 700;
  }
  .toc-num.c1 { background: rgba(239,68,68,0.15); color: #ef4444; }
  .toc-num.c2 { background: rgba(20,184,166,0.15); color: #14b8a6; }
  .toc-card-body h4 {
    font-size: 0.92rem;
    font-weight: 600;
    margin-bottom: 3px;
  }
  .toc-card-body p {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  /* === 通用段落 === */
  .report-section {
    padding: 60px 0 40px;
    border-top: 1px solid var(--border);
  }

  .report-header {
    margin-bottom: 36px;
  }
  .report-header .severity-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 14px;
    border-radius: 6px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .severity-badge.critical {
    background: rgba(239,68,68,0.15);
    color: #fca5a5;
    border: 1px solid rgba(239,68,68,0.3);
  }
  .severity-badge.info {
    background: rgba(6,182,212,0.15);
    color: #67e8f9;
    border: 1px solid rgba(6,182,212,0.3);
  }

  .report-header h2 {
    font-size: 1.7rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 8px;
  }
  .report-header p {
    color: var(--text-secondary);
    font-size: 0.92rem;
    max-width: 700px;
  }

  /* === 统计卡片 === */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
    margin-bottom: 36px;
  }
  .stat-card {
    padding: 18px 20px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: all 0.3s ease;
  }
  .stat-card:hover {
    border-color: var(--border-accent);
    box-shadow: var(--shadow-glow);
  }
  .stat-card .stat-label {
    font-size: 0.72rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 6px;
  }
  .stat-card .stat-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.4rem;
    font-weight: 700;
  }
  .stat-card .stat-value.danger { color: var(--danger); }
  .stat-card .stat-value.accent { color: var(--accent-bright); }
  .stat-card .stat-value.warning { color: var(--warning); }
  .stat-card .stat-value.info { color: var(--info); }
  .stat-card .stat-sub {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: 2px;
  }

  /* === 卡片 === */
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    margin-bottom: 20px;
    transition: border-color 0.3s ease;
  }
  .card:hover {
    border-color: rgba(20,184,166,0.2);
  }
  .card-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 18px;
  }
  .card-title i {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-size: 0.85rem;
  }
  .card-title i.teal { background: rgba(20,184,166,0.15); color: var(--accent-bright); }
  .card-title i.red { background: rgba(239,68,68,0.15); color: #fca5a5; }
  .card-title i.amber { background: rgba(245,158,11,0.15); color: #fcd34d; }
  .card-title i.cyan { background: rgba(6,182,212,0.15); color: #67e8f9; }
  .card-title i.purple { background: rgba(167,139,250,0.15); color: #c4b5fd; }

  /* === 表格 === */
  .table-wrap {
    overflow-x: auto;
    margin-top: 12px;
    border-radius: 8px;
    border: 1px solid var(--border);
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
  }
  thead {
    background: var(--bg-elevated);
  }
  th {
    padding: 10px 14px;
    text-align: left;
    font-weight: 600;
    color: var(--text-secondary);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  td {
    padding: 10px 14px;
    border-bottom: 1px solid rgba(30,45,61,0.5);
    color: var(--text-secondary);
    vertical-align: top;
  }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(20,184,166,0.03); }
  td.mono {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--text-primary);
  }

  /* === 风险标签 === */
  .risk-tag {
    display: inline-flex;
    align-items: center;
    padding: 2px 10px;
    border-radius: 4px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .risk-tag.critical { background: rgba(239,68,68,0.15); color: #fca5a5; }
  .risk-tag.high { background: rgba(245,158,11,0.15); color: #fcd34d; }
  .risk-tag.medium { background: rgba(6,182,212,0.15); color: #67e8f9; }
  .risk-tag.low { background: rgba(34,197,94,0.15); color: #86efac; }

  /* === SPL代码块 === */
  .spl-block {
    background: #0b0f1a;
    border: 1px solid var(--border);
    border-radius: 8px;
    margin: 12px 0 8px;
    overflow: hidden;
  }
  .spl-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 14px;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .spl-header .spl-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .spl-copy {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.72rem;
    padding: 3px 8px;
    border-radius: 4px;
    transition: all 0.2s;
  }
  .spl-copy:hover { background: rgba(255,255,255,0.06); color: var(--text-primary); }
  .spl-body {
    padding: 14px 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    line-height: 1.7;
    color: var(--text-secondary);
    overflow-x: auto;
    white-space: pre;
  }
  .spl-body .kw { color: var(--accent-bright); }
  .spl-body .str { color: #fcd34d; }
  .spl-body .cm { color: var(--text-muted); font-style: italic; }
  .spl-body .pipe { color: var(--info); }

  /* === 时间线 === */
  .timeline {
    position: relative;
    padding-left: 28px;
    margin: 16px 0;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 8px;
    top: 4px;
    bottom: 4px;
    width: 2px;
    background: linear-gradient(to bottom, var(--accent), var(--border));
    border-radius: 2px;
  }
  .timeline-item {
    position: relative;
    padding-bottom: 20px;
  }
  .timeline-item:last-child { padding-bottom: 0; }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: -24px;
    top: 6px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    border: 2px solid var(--bg-deep);
    box-shadow: 0 0 8px rgba(20,184,166,0.4);
  }
  .timeline-item.active::before {
    background: var(--danger);
    box-shadow: 0 0 8px rgba(239,68,68,0.4);
  }
  .timeline-time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 2px;
  }
  .timeline-item.active .timeline-time { color: var(--danger); }
  .timeline-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  .timeline-desc strong { color: var(--text-primary); font-weight: 600; }

  /* === MITRE标签 === */
  .mitre-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 12px;
  }
  .mitre-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 16px;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .mitre-id {
    flex-shrink: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 3px 8px;
    background: rgba(167,139,250,0.15);
    color: var(--purple);
    border-radius: 4px;
    white-space: nowrap;
  }
  .mitre-item .mitre-tactic {
    font-size: 0.68rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .mitre-item .mitre-name {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-primary);
  }
  .mitre-item .mitre-evidence {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 3px;
    line-height: 1.4;
  }

  /* === 建议优先级 === */
  .rec-card {
    padding: 16px 20px;
    border-radius: 8px;
    border-left: 3px solid;
    margin-bottom: 10px;
  }
  .rec-card.critical { background: rgba(239,68,68,0.06); border-color: var(--danger); }
  .rec-card.high { background: rgba(245,158,11,0.06); border-color: var(--warning); }
  .rec-card.medium { background: rgba(6,182,212,0.06); border-color: var(--info); }
  .rec-card .rec-head {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }
  .rec-card .rec-priority {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 1px 8px;
    border-radius: 3px;
  }
  .rec-card.critical .rec-priority { background: rgba(239,68,68,0.2); color: #fca5a5; }
  .rec-card.high .rec-priority { background: rgba(245,158,11,0.2); color: #fcd34d; }
  .rec-card.medium .rec-priority { background: rgba(6,182,212,0.2); color: #67e8f9; }
  .rec-card .rec-action { font-size: 0.85rem; font-weight: 500; color: var(--text-primary); }
  .rec-card .rec-team { font-size: 0.72rem; color: var(--text-muted); margin-top: 2px; }

  /* === 子标题 === */
  .sub-heading {
    font-size: 1.12rem;
    font-weight: 600;
    margin: 32px 0 14px;
    padding-left: 14px;
    border-left: 3px solid var(--accent);
    color: var(--text-primary);
  }

  .text-body {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.75;
    margin-bottom: 16px;
  }

  /* === 进度条 === */
  .bar-chart-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }
  .bar-label {
    flex-shrink: 0;
    width: 130px;
    font-size: 0.78rem;
    font-family: 'JetBrains Mono', monospace;
    color: var(--text-secondary);
    text-align: right;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .bar-track {
    flex: 1;
    height: 22px;
    background: var(--bg-elevated);
    border-radius: 4px;
    overflow: hidden;
    position: relative;
  }
  .bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
  }
  .bar-fill.danger { background: linear-gradient(90deg, rgba(239,68,68,0.7), rgba(239,68,68,0.4)); }
  .bar-fill.accent { background: linear-gradient(90deg, rgba(20,184,166,0.7), rgba(20,184,166,0.4)); }
  .bar-fill.warning { background: linear-gradient(90deg, rgba(245,158,11,0.7), rgba(245,158,11,0.4)); }
  .bar-fill.info { background: linear-gradient(90deg, rgba(6,182,212,0.7), rgba(6,182,212,0.4)); }
  .bar-value {
    flex-shrink: 0;
    width: 80px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  /* === 页脚 === */
  .doc-footer {
    padding: 48px 0;
    border-top: 1px solid var(--border);
    text-align: center;
  }
  .doc-footer .confidential {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--danger);
    font-weight: 700;
    margin-bottom: 10px;
  }
  .doc-footer p {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* === 滚动显示动画 === */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* === 关键帧 === */
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(-8px); }
  }

